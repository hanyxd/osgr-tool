def load_config(path: Optional[Path] = None) -> AppConfig:
    if path and path.exists():
        data = yaml.safe_load(path.read_text())
        return AppConfig(**data)
    return AppConfig()

def save_config(config: AppConfig, path: Path):
    data = asdict(config)
    # Convert ProxyConfig, AuthConfig, NotificationConfig to dict
    data["proxies"] = [asdict(p) for p in config.proxies]
    data["auth"] = [asdict(a) for a in config.auth]
    if config.notifications:
        data["notifications"] = asdict(config.notifications)
    path.write_text(yaml.dump(data, default_flow_style=False))

async def main():
    parser = argparse.ArgumentParser(
        description="sherlockV2 - Next-Gen Username OSINT Tool",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  sherlockV2 targetuser                          # Basic scan
  sherlockV2 user1 user2 --full                  # Full scan with all outputs
  sherlockV2 target --sites github twitter       # Specific sites
  sherlockV2 target --categories social,code     # By category
  sherlockV2 target --monitor --interval 3600    # Continuous monitoring
  sherlockV2 target --config config.yaml         # Custom config
  sherlockV2 --list-sites                        # List all sites
  sherlockV2 --list-categories                   # List categories
        """
    )
    parser.add_argument("usernames", nargs="*", help="Usernames to check")
    parser.add_argument("--sites", "-s", nargs="+", help="Specific sites to check")
    parser.add_argument("--categories", "-c", nargs="+", help="Categories to check")
    parser.add_argument("--full", action="store_true", help="Check all sites")
    parser.add_argument("--formats", "-f", nargs="+", default=["json", "csv", "md"],
                        choices=["json", "csv", "xlsx", "md", "html", "sqlite"],
                        help="Output formats")
    parser.add_argument("--output", "-o", default="./results", help="Output directory")
    parser.add_argument("--config", help="Config file path")
    parser.add_argument("--save-config", help="Save default config to file")
    parser.add_argument("--list-sites", action="store_true", help="List all available sites")
    parser.add_argument("--list-categories", action="store_true", help="List all categories")
    parser.add_argument("--monitor", action="store_true", help="Continuous monitoring mode")
    parser.add_argument("--interval", type=int, default=3600, help="Monitor interval (seconds)")
    parser.add_argument("--concurrency", type=int, default=50, help="Max concurrent requests")
    parser.add_argument("--timeout", type=int, default=30, help="Request timeout (seconds)")
    parser.add_argument("--rate-limit", type=float, default=1.0, help="Default rate limit (req/sec)")
    parser.add_argument("--proxy", nargs="+", help="Proxy URLs (socks5://, http://)")
    parser.add_argument("--tor", action="store_true", help="Use Tor (socks5://127.0.0.1:9050)")
    parser.add_argument("--no-progress", action="store_true", help="Disable progress bar")
    parser.add_argument("--verbose", "-v", action="store_true", help="Verbose logging")
    parser.add_argument("--version", action="store_true", help="Show version")

    args = parser.parse_args()

    if args.version:
        print("sherlockV2 v1.0.0")
        return

    if args.save_config:
        save_config(AppConfig(), Path(args.save_config))
        print(f"Config saved to {args.save_config}")
        return

    config = load_config(Path(args.config) if args.config else None)
    config.concurrency = args.concurrency
    config.default_timeout = args.timeout
    config.default_rate_limit = args.rate_limit
    config.output_dir = args.output

    if args.proxy:
        config.proxies = [ProxyConfig(url=p) for p in args.proxy]
    if args.tor:
        config.proxies.append(ProxyConfig(url="socks5://127.0.0.1:9050"))

    if args.verbose:
        config.log_level = "DEBUG"

    engine = SherlockX(config)

    if args.list_sites:
        for cat in engine.registry.categories():
            sites = engine.registry.list(category=cat)
            print(f"\n{cat.upper()} ({len(sites)})")
            for s in sites:
                print(f"  {s.name} ({'disabled' if s.disabled else 'enabled'})")
        return

    if args.list_categories:
        for cat in engine.registry.categories():
            count = len(engine.registry.list(category=cat))
            print(f"  {cat} ({count})")
        return

    if not args.usernames and not args.monitor:
        parser.print_help()
        return

    if args.monitor:
        if not args.usernames:
            print("Error: --monitor requires usernames")
            return
        await engine.monitor(args.usernames, args.interval)
        return

    reports = await engine.scan(
        args.usernames,
        sites=args.sites if args.sites else None,
        categories=args.categories if args.categories else None,
        formats=args.formats,
        progress=not args.no_progress
    )

    # Summary
    total_claimed = sum(r.claimed_count for r in reports)
    print(f"\n✅ Done. Total claimed: {total_claimed}")

if __name__ == "__main__":
    try:
        asyncio.run(main())
    except KeyboardInterrupt:
        print("\nInterrupted")
        sys.exit(1)