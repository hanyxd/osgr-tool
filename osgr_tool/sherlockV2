        if key in self.sites:
            self.sites[key].disabled = False

    def disable(self, key: str):
        if key in self.sites:
            self.sites[key].disabled = True

    def get(self, key: str) -> Optional[SiteConfig]:
        return self.sites.get(key)

    def list(self, enabled_only: bool = True, category: Optional[str] = None) -> List[SiteConfig]:
        sites = list(self.sites.values())
        if enabled_only:
            sites = [s for s in sites if not s.disabled]
        if category:
            sites = [s for s in sites if s.category == category]
        return sorted(sites, key=lambda s: -s.priority)

    def categories(self) -> List[str]:
        return sorted(set(s.category for s in self.sites.values()))

    def load_from_file(self, path: Path):
        data = yaml.safe_load(path.read_text())
        for key, config in data.get("sites", {}).items():
            self.register(key, SiteConfig(**config))

# ─── Rate Limiter ─────────────────────────────────────────────────────────

class RateLimiter:
    def __init__(self, default_rate: float = 1.0):
        self.default_rate = default_rate
        self.last_request: Dict[str, float] = {}
        self.lock = asyncio.Lock()

    async def wait(self, site: str, rate: float = None):
        rate = rate or self.default_rate
        async with self.lock:
            now = time.monotonic()
            last = self.last_request.get(site, 0)
            elapsed = now - last
            if elapsed < rate:
                await asyncio.sleep(rate - elapsed)
            self.last_request[site] = time.monotonic()

# ─── HTTP Client ──────────────────────────────────────────────────────────

class HTTPClient:
    def __init__(self, config: AppConfig, rate_limiter: RateLimiter):
        self.config = config
        self.rate_limiter = rate_limiter
        self.session: Optional[aiohttp.ClientSession] = None
        self.proxy_pool: List[str] = [p.url for p in config.proxies]

    async def __aenter__(self):
        connector = None
        if self.proxy_pool and HAS_SOCKS:
            connector = ProxyConnector.from_url(self.proxy_pool[0])
        elif self.proxy_pool:
            connector = aiohttp.TCPConnector(limit=100)

        timeout = aiohttp.ClientTimeout(total=self.config.default_timeout)
        self.session = aiohttp.ClientSession(
            connector=connector,
            timeout=timeout,
            headers={"User-Agent": secrets.choice(self.config.user_agents)},
            cookie_jar=aiohttp.CookieJar(unsafe=True),
        )
        return self

    async def __aexit__(self, exc_type, exc_val, exc_tb):
        if self.session:
            await self.session.close()

    def _get_proxy(self) -> Optional[str]:
        if not self.proxy_pool:
            return None
        return secrets.choice(self.proxy_pool)

    def _get_auth(self, site: str) -> Optional[aiohttp.BasicAuth]:
        for auth in self.config.auth:
            if auth.site == site:
                if auth.type == "basic":
                    return aiohttp.BasicAuth(auth.credentials["username"], auth.credentials["password"])
        return None

    async def request(self, site_config: SiteConfig, username: str) -> Tuple[CheckResult, Optional[aiohttp.ClientResponse]]:
        url = site_config.url.format(username=username)
        method = site_config.method.upper()
        headers = {**site_config.headers}
        cookies = {**site_config.cookies}
        data = site_config.data.copy() if site_config.data else None
        auth = self._get_auth(site_config.name)

        # Apply auth headers
        for auth_cfg in self.config.auth:
            if auth_cfg.site == site_config.name:
                if auth_cfg.type == "bearer":
                    headers["Authorization"] = f"Bearer {auth_cfg.credentials['token']}"
                elif auth_cfg.type == "cookie":
                    cookies.update(auth_cfg.credentials)

        await self.rate_limiter.wait(site_config.name, site_config.rate_limit)

        start = time.monotonic()
        try:
            async with self.session.request(
                method, url, headers=headers, cookies=cookies, data=data, auth=auth,
                allow_redirects=True
            ) as resp:
                response_time = time.monotonic() - start
                text = await resp.text()
                return CheckResult(
                    site=site_config.name,
                    username=username,
                    status=ResultStatus.UNKNOWN,
                    url=str(resp.url),
                    response_time=response_time,
                    headers=dict(resp.headers),
                    raw_response=text[:5000],
                ), resp
        except asyncio.TimeoutError:
            return CheckResult(
                site=site_config.name,
                username=username,
                status=ResultStatus.ERROR,
                url=url,
                response_time=time.monotonic() - start,
                error="Timeout",
            ), None
        except aiohttp.ClientError as e:
            return CheckResult(
                site=site_config.name,
                username=username,
                status=ResultStatus.ERROR,
                url=url,
                response_time=time.monotonic() - start,
                error=str(e),
            ), None
        except Exception as e:
            return CheckResult(
                site=site_config.name,
                username=username,
                status=ResultStatus.ERROR,
                url=url,
                response_time=time.monotonic() - start,
                error=f"Unexpected: {e}",
            ), None

# ─── Extractors ───────────────────────────────────────────────────────────

class Extractor(ABC):
    @abstractmethod
    def extract(self, html: str, url: str) -> Dict[str, Any]:
        pass

class RegexExtractor(Extractor):
    def __init__(self, pattern: str, field: str, group: int = 1):
        self.pattern = re.compile(pattern)
        self.field = field
        self.group = group

    def extract(self, html: str, url: str) -> Dict[str, Any]:
        match = self.pattern.search(html)
        if match:
            return {self.field: match.group(self.group)}
        return {}

class JSONExtractor(Extractor):
    def __init__(self, path: str, field: str):
        self.path = path.split(".")
        self.field = field

    def extract(self, html: str, url: str) -> Dict[str, Any]:
        try:
            data = json.loads(html)
            for key in self.path:
                data = data[key]
            return {self.field: data}
        except Exception:
            return {}

class MetaExtractor(Extractor):
    def extract(self, html: str, url: str) -> Dict[str, Any]:
        result = {}
        for prop, field in [
            ("og:title", "title"),
            ("og:description", "description"),
            ("og:image", "image"),
            ("og:url", "canonical_url"),
            ("twitter:card", "twitter_card"),
            ("twitter:site", "twitter_site"),
            ("twitter:creator", "twitter_creator"),
        ]:
            pattern = rf'<meta property="{prop}" content="([^"]+)"'
            match = re.search(pattern, html)
            if match:
                result[field] = match.group(1)
        return result

class SchemaExtractor(Extractor):
    def extract(self, html: str, url: str) -> Dict[str, Any]:
        result = {}
        # JSON-LD
        for match in re.finditer(r'<script type="application/ld\+json">(.*?)</script>', html, re.DOTALL):
            try:
                data = json.loads(match.group(1))
                if isinstance(data, list):
                    data = data[0]
                if isinstance(data, dict):
                    result.update({
                        "name": data.get("name"),
                        "description": data.get("description"),
                        "url": data.get("url"),
                        "image": data.get("image"),
                        "sameAs": data.get("sameAs"),
                    })
            except Exception:
                pass
        return result

EXTRACTORS = {
    "regex": lambda c: RegexExtractor(c["pattern"], c["field"], c.get("group", 1)),
    "json": lambda c: JSONExtractor(c["path"], c["field"]),
    "meta": lambda _: MetaExtractor(),
    "schema": lambda _: SchemaExtractor(),
}

# ─── Site Checker ─────────────────────────────────────────────────────────

class SiteChecker:
    def __init__(self, client: HTTPClient, registry: SiteRegistry):
        self.client = client
        self.registry = registry

    async def check(self, site_key: str, username: str) -> CheckResult:
        site = self.registry.get(site_key)
        if not site or site.disabled:
            return CheckResult(
                site=site_key, username=username,
                status=ResultStatus.UNKNOWN, url="", response_time=0,
                error="Site not found or disabled"
            )

        result, response = await self.client.request(site, username)
        if not response:
            return result

        # Determine status
        result = await self._evaluate_status(site, username, result, response)
        return result

    async def _evaluate_status(self, site: SiteConfig, username: str,
                                result: CheckResult, response: aiohttp.ClientResponse) -> CheckResult:
        html = result.raw_response or ""

        # Check for blocked indicators
        for indicator in site.blocked_indicators:
            if indicator in html:
                result.status = ResultStatus.BLOCKED
                result.error = f"Blocked: {indicator}"
                return result

        # Rate limiting
        if response.status == 429:
            result.status = ResultStatus.RATE_LIMITED
            result.error = "Rate limited"
            return result

        # Error-based detection
        if site.error_type == "status_code":
            if response.status == 404:
                result.status = ResultStatus.UNCLAIMED
            elif response.status == 200:
                result.status = ResultStatus.CLAIMED
            else:
                result.status = ResultStatus.ERROR
                result.error = f"HTTP {response.status}"

        elif site.error_type == "text_contains":
            if any(val in html for val in site.error_values):
                result.status = ResultStatus.UNCLAIMED
            else:
                result.status = ResultStatus.CLAIMED

        elif site.error_type == "text_not_contains":
            if all(val not in html for val in site.error_values):
                result.status = ResultStatus.CLAIMED
            else:
                result.status = ResultStatus.UNCLAIMED

        elif site.error_type == "regex":
            for pattern in site.error_values:
                if re.search(pattern, html):
                    result.status = ResultStatus.UNCLAIMED
                    break
            else:
                result.status = ResultStatus.CLAIMED

        # Extract profile data if claimed
        if result.status == ResultStatus.CLAIMED:
            result.profile_data = await self._extract_profile(site, result.raw_response or "", str(response.url))

        return result

    async def _extract_profile(self, site: SiteConfig, html: str, url: str) -> Dict[str, Any]:
        data = {}
        for extractor_config in site.extractors:
            try:
                extractor = EXTRACTORS[extractor_config["type"]](extractor_config)
                data.update(extractor.extract(html, url))
            except Exception:
                pass
        return data

    async def check_multiple(self, sites: List[str], username: str,
                             progress_callback: Optional[callable] = None) -> List[CheckResult]:
        semaphore = asyncio.Semaphore(self.client.config.concurrency)

        async def check_one(site_key: str):
            async with semaphore:
                return await self.check(site_key, username)

        tasks = [check_one(site) for site in sites]
        results = []

        for coro in asyncio.as_completed(tasks):
            result = await coro
            results.append(result)
            if progress_callback:
                await progress_callback(result)

        return results

# ─── Database ─────────────────────────────────────────────────────────────

class Database:
    def __init__(self, db_path: str):
        self.db_path = db_path.replace("sqlite:///", "")
        Path(self.db_path).parent.mkdir(parents=True, exist_ok=True)
        self._init_db()

    def _init_db(self):
        with sqlite3.connect(self.db_path) as conn:
            conn.execute("""
                CREATE TABLE IF NOT EXISTS checks (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    username TEXT NOT NULL,
                    site TEXT NOT NULL,
                    status TEXT NOT NULL,
                    url TEXT,
                    response_time REAL,
                    timestamp TEXT NOT NULL,
                    profile_data TEXT,
                    error TEXT,
                    UNIQUE(username, site)
                )
            """)
            conn.execute("CREATE INDEX IF NOT EXISTS idx_username ON checks(username)")
            conn.execute("CREATE INDEX IF NOT EXISTS idx_site ON checks(site)")
            conn.execute("CREATE INDEX IF NOT EXISTS idx_timestamp ON checks(timestamp)")

    async def save_result(self, result: CheckResult):
        async with aiosqlite.connect(self.db_path) as db:
            await db.execute("""
                INSERT OR REPLACE INTO checks
                (username, site, status, url, response_time, timestamp, profile_data, error)
                VALUES (?, ?, ?, ?, ?, ?, ?, ?)
            """, (
                result.username, result.site, result.status.value,
                result.url, result.response_time,
                result.timestamp.isoformat(),
                json.dumps(result.profile_data),
                result.error
            ))
            await db.commit()

    async def get_history(self, username: str, site: Optional[str] = None, limit: int = 100) -> List[Dict]:
        async with aiosqlite.connect(self.db_path) as db:
            db.row_factory = aiosqlite.Row
            query = "SELECT * FROM checks WHERE username = ?"
            params = [username]
            if site:
                query += " AND site = ?"
                params.append(site)
            query += " ORDER BY timestamp DESC LIMIT ?"
            params.append(limit)
            cursor = await db.execute(query, params)
            return [dict(row) for row in await cursor.fetchall()]

    async def get_stats(self) -> Dict:
        async with aiosqlite.connect(self.db_path) as db:
            stats = {}
            stats["total_checks"] = (await db.execute("SELECT COUNT(*) FROM checks")).fetchone()[0]
            stats["unique_usernames"] = (await db.execute("SELECT COUNT(DISTINCT username) FROM checks")).fetchone()[0]
            stats["unique_sites"] = (await db.execute("SELECT COUNT(DISTINCT site) FROM checks")).fetchone()[0]
            stats["claimed"] = (await db.execute("SELECT COUNT(*) FROM checks WHERE status = 'claimed'")).fetchone()[0]
            stats["unclaimed"] = (await db.execute("SELECT COUNT(*) FROM checks WHERE status = 'unclaimed'")).fetchone()[0]
            return stats

# ─── Notifications ────────────────────────────────────────────────────────

class Notifier:
    def __init__(self, config: NotificationConfig):
        self.config = config
        self.http: Optional[aiohttp.ClientSession] = None

    async def __aenter__(self):
        self.http = aiohttp.ClientSession()
        return self

    async def __aexit__(self, *args):
        if self.http:
            await self.http.close()

    async def notify(self, message: str, report: UsernameReport):
        tasks = []
        if self.config.discord_webhook:
            tasks.append(self._discord(message, report))
        if self.config.telegram_bot_token and self.config.telegram_chat_id:
            tasks.append(self._telegram(message, report))
        if self.config.slack_webhook:
            tasks.append(self._slack(message, report))
        if self.config.ntfy_topic:
            tasks.append(self._ntfy(message, report))
        if self.config.pushover_token and self.config.pushover_user:
            tasks.append(self._pushover(message, report))
        if tasks:
            await asyncio.gather(*tasks, return_exceptions=True)

    def _format_report(self, report: UsernameReport) -> str:
        lines = [f"🔍 **{report.username}** - Scan Complete"]
        lines.append(f"✅ Claimed: {report.claimed_count} | ❌ Unclaimed: {report.unclaimed_count} | ⚠️ Errors: {report.error_count}")
        for r in report.results:
            if r.status == ResultStatus.CLAIMED:
                lines.append(f"  ✅ {r.site}: {r.url}")
        return "\n".join(lines)

    async def _discord(self, message: str, report: UsernameReport):
        content = self._format_report(report)
        await self.http.post(self.config.discord_webhook, json={"content": content})

    async def _telegram(self, message: str, report: UsernameReport):
        content = self._format_report(report)
        url = f"https://api.telegram.org/bot{self.config.telegram_bot_token}/sendMessage"
        await self.http.post(url, json={"chat_id": self.config.telegram_chat_id, "text": content, "parse_mode": "Markdown"})

    async def _slack(self, message: str, report: UsernameReport):
        content = self._format_report(report)
        await self.http.post(self.config.slack_webhook, json={"text": content})

    async def _ntfy(self, message: str, report: UsernameReport):
        content = self._format_report(report)
        await self.http.post(f"https://ntfy.sh/{self.config.ntfy_topic}", data=content)

    async def _pushover(self, message: str, report: UsernameReport):
        content = self._format_report(report)
        await self.http.post("https://api.pushover.net/1/messages.json", data={
            "token": self.config.pushover_token,
            "user": self.config.pushover_user,
            "message": content,
        })

# ─── Output Writers ───────────────────────────────────────────────────────

class OutputWriter:
    def __init__(self, output_dir: Path):
        self.output_dir = output_dir
        self.output_dir.mkdir(parents=True, exist_ok=True)

    def write(self, report: UsernameReport, formats: List[str]):
        timestamp = report.started_at.strftime("%Y%m%d_%H%M%S")
        base = self.output_dir / f"{report.username}_{timestamp}"

        for fmt in formats:
            if fmt == "json":
                self._write_json(base, report)
            elif fmt == "csv":
                self._write_csv(base, report)
            elif fmt == "xlsx":
                self._write_xlsx(base, report)
            elif fmt == "md":
                self._write_md(base, report)
            elif fmt == "html":
                self._write_html(base, report)
            elif fmt == "sqlite":
                self._write_sqlite(base, report)

    def _write_json(self, base: Path, report: UsernameReport):
        (base.with_suffix(".json")).write_text(json.dumps(report.to_dict(), indent=2))

    def _write_csv(self, base: Path, report: UsernameReport):
        with open(base.with_suffix(".csv"), "w", newline="") as f:
            writer = csv.DictWriter(f, fieldnames=[
                "site", "username", "status", "url", "response_time",
                "timestamp", "error", "profile_data"
            ])
            writer.writeheader()
            for r in report.results:
                row = r.to_dict()
                # Remove extra fields
                row.pop("headers", None)
                row.pop("raw_response", None)
                row["profile_data"] = json.dumps(row["profile_data"])
                writer.writerow(row)

    def _write_xlsx(self, base: Path, report: UsernameReport):
        try:
            import openpyxl
            wb = openpyxl.Workbook()
            ws = wb.active
            ws.title = "Results"
            headers = ["Site", "Username", "Status", "URL", "Response Time", "Timestamp", "Error", "Profile Data"]
            ws.append(headers)
            for r in report.results:
                row = r.to_dict()
                row["profile_data"] = json.dumps(row["profile_data"])
                ws.append([row.get(h.lower().replace(" ", "_"), "") for h in headers])
            wb.save(base.with_suffix(".xlsx"))
        except ImportError:
            pass

    def _write_md(self, base: Path, report: UsernameReport):
        lines = [
            f"# OSINT Report: @{report.username}",
            f"Generated: {report.started_at.isoformat()}",
            f"Completed: {report.completed_at.isoformat() if report.completed_at else 'N/A'}",
            "",
            f"## Summary",
            f"- **Total Sites:** {report.total_sites}",
            f"- **✅ Claimed:** {report.claimed_count}",
            f"- **❌ Unclaimed:** {report.unclaimed_count}",
            f"- **⚠️ Errors:** {report.error_count}",
            "",
            "## Results",
            "| Site | Status | URL | Response Time | Error |",
            "|------|--------|-----|---------------|-------|",
        ]
        for r in sorted(report.results, key=lambda x: x.site):
            status_emoji = {"claimed": "✅", "unclaimed": "❌", "error": "⚠️", "rate_limited": "🚫", "blocked": "🛑"}.get(r.status.value, "❓")
            error = r.error or ""
            lines.append(f"| {r.site} | {status_emoji} {r.status.value} | {r.url} | {r.response_time:.2f}s | {error} |")

        (base.with_suffix(".md")).write_text("\n".join(lines))

    def _write_html(self, base: Path, report: UsernameReport):
        html = f"""<!DOCTYPE html>
<html><head><title>OSINT Report: @{report.username}</title>
<style>
body {{ font-family: system-ui; max-width: 1200px; margin: 2rem auto; padding: 0 1rem; }}
table {{ width: 100%; border-collapse: collapse; }}
th, td {{ padding: 0.5rem; border: 1px solid #ddd; text-align: left; }}
th {{ background: #f5f5f5; }}
.claimed {{ color: green; }} .unclaimed {{ color: red; }}
.error {{ color: orange; }} .rate_limited {{ color: purple; }}
.blocked {{ color: darkred; }}
tr:hover {{ background: #f9f9f9; }}
</style></head><body>
<h1>OSINT Report: @{report.username}</h1>
<p>Generated: {report.started_at.isoformat()}</p>
<p>Total: {report.total_sites} | Claimed: {report.claimed_count} | Unclaimed: {report.unclaimed_count} | Errors: {report.error_count}</p>
<table><thead><tr><th>Site</th><th>Status</th><th>URL</th><th>Response Time</th><th>Error</th></tr></thead><tbody>
"""
        for r in sorted(report.results, key=lambda x: x.site):
            status_class = r.status.value
            error = r.error or ""
            html += f"<tr><td>{r.site}</td><td class='{status_class}'>{r.status.value}</td><td><a href='{r.url}' target='_blank'>{r.url}</a></td><td>{r.response_time:.2f}s</td><td>{error}</td></tr>"
        html += "</tbody></table></body></html>"
        (base.with_suffix(".html")).write_text(html)

    def _write_sqlite(self, base: Path, report: UsernameReport):
        db = sqlite3.connect(base.with_suffix(".sqlite"))
        db.execute("""
            CREATE TABLE IF NOT EXISTS results (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                username TEXT, site TEXT, status TEXT, url TEXT,
                response_time REAL, timestamp TEXT, profile_data TEXT, error TEXT
            )
        """)
        for r in report.results:
            db.execute("""
                INSERT INTO results VALUES (NULL, ?, ?, ?, ?, ?, ?, ?, ?)
            """, (r.username, r.site, r.status.value, r.url, r.response_time,
                  r.timestamp.isoformat(), json.dumps(r.profile_data), r.error))
        db.commit()
        db.close()

