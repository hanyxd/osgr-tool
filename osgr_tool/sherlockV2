class SherlockX:
    def __init__(self, config: AppConfig):
        self.config = config
        self.registry = SiteRegistry()
        self.rate_limiter = RateLimiter(config.default_rate_limit)
        self.db = Database(config.database)
        self._setup_logging()

    def _setup_logging(self):
        log_level = getattr(logging, self.config.log_level.upper())
        handlers = [logging.StreamHandler(sys.stdout)]
        if self.config.log_file:
            handlers.append(RotatingFileHandler(self.config.log_file, maxBytes=10*1024*1024, backupCount=5))
        logging.basicConfig(level=log_level, format="%(asctime)s | %(levelname)s | %(message)s", handlers=handlers)
        self.logger = logging.getLogger("sherlockV2")

    async def scan(self, usernames: List[str], sites: Optional[List[str]] = None,
                   categories: Optional[List[str]] = None, formats: List[str] = None,
                   progress: bool = True) -> List[UsernameReport]:
        formats = formats or ["json", "csv", "md"]
        target_sites = self._resolve_sites(sites, categories)

        async with HTTPClient(self.config, self.rate_limiter) as client:
            checker = SiteChecker(client, self.registry)
            writer = OutputWriter(Path(self.config.output_dir))

            if progress and HAS_RICH:
                return await self._scan_with_rich_progress(usernames, target_sites, checker, writer, formats)
            else:
                return await self._scan_simple(usernames, target_sites, checker, writer, formats)

    def _resolve_sites(self, sites: Optional[List[str]], categories: Optional[List[str]]) -> List[str]:
        if sites:
            return [s for s in sites if s in self.registry.sites]
        if categories:
            return [s.name for s in self.registry.list(category=categories[0])]
        return [s.name for s in self.registry.list()]

    async def _scan_simple(self, usernames, sites, checker, writer, formats):
        reports = []
        for username in usernames:
            report = await self._scan_username(username, sites, checker)
            writer.write(report, formats)
            await self._save_to_db(report)
            reports.append(report)
        return reports

    async def _scan_with_rich_progress(self, usernames, sites, checker, writer, formats):
        console = Console()
        reports = []

        with Progress(
            SpinnerColumn(), TextColumn("[progress.description]{task.description}"),
            BarColumn(), TaskProgressColumn(), TimeRemainingColumn(), console=console
        ) as progress:
            for username in usernames:
                task = progress.add_task(f"Scanning @{username}", total=len(sites))
                results = []

                async def update_progress(result):
                    progress.advance(task)
                    results.append(result)

                report = UsernameReport(username=username)
                raw_results = await checker.check_multiple(sites, username, update_progress)
                for r in raw_results:
                    report.add_result(r)
                report.finish()

                writer.write(report, formats)
                await self._save_to_db(report)
                reports.append(report)
                progress.remove_task(task)

                # Print summary
                table = Table(title=f"@{username} Results", box=box.ROUNDED)
                table.add_column("Status", style="bold")
                table.add_column("Count", justify="right")
                table.add_row("✅ Claimed", str(report.claimed_count), style="green")
                table.add_row("❌ Unclaimed", str(report.unclaimed_count), style="red")
                table.add_row("⚠️ Errors", str(report.error_count), style="yellow")
                console.print(table)

        return reports

    async def _scan_username(self, username: str, sites: List[str], checker: SiteChecker) -> UsernameReport:
        report = UsernameReport(username=username)
        results = await checker.check_multiple(sites, username)
        for r in results:
            report.add_result(r)
        report.finish()
        return report

    async def _save_to_db(self, report: UsernameReport):
        for result in report.results:
            await self.db.save_result(result)

    async def monitor(self, usernames: List[str], interval: int = 3600,
                      callback: Optional[callable] = None):
        """Monitor usernames for changes."""
        self.logger.info(f"Starting monitor for {len(usernames)} usernames, interval: {interval}s")
        last_results = {}

        async with HTTPClient(self.config, self.rate_limiter) as client:
            checker = SiteChecker(client, self.registry)
            notifier = Notifier(self.config.notifications) if self.config.notifications else None

            while True:
                for username in usernames:
                    sites = [s.name for s in self.registry.list()]
                    report = await self._scan_username(username, sites, checker)

                    # Compare with last results
                    if username in last_results:
                        await self._detect_changes(username, last_results[username], report, notifier)

                    last_results[username] = {r.site: r.status for r in report.results}

                    if callback:
                        await callback(report)

                await asyncio.sleep(interval)

    async def _detect_changes(self, username: str, old: Dict, new_report: UsernameReport, notifier: Optional[Notifier]):
        changes = []
        for r in new_report.results:
            old_status = old.get(r.site)
            if old_status and old_status != r.status.value:
                changes.append(f"{r.site}: {old_status} → {r.status.value}")

        if changes and notifier:
            await notifier.notify(f"🔔 Changes detected for @{username}:\n" + "\n".join(changes), new_report)

