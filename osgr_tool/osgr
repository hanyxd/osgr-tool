def format_output(data: Dict, verbose: bool = False):
    p = data['profile']
    a = data.get('analysis', {})
    fa = data.get('followers_analysis', {})

    # Header
    print(f"\n{bold('='*60)}")
    print(f"  {bold('@' + p['username'])}  |  {p['full_name'] or 'N/A'}")
    print(f"{bold('='*60)}")

    # Basic info
    info = [
        ("Name", p['full_name'] or 'N/A'),
        ("Bio", (p['biography'][:80] + '...') if p['biography'] and len(p['biography']) > 80 else p['biography'] or 'N/A'),
        ("Followers", f"{p['followers']:,}"),
        ("Following", f"{p['following']:,}"),
        ("Posts", f"{p['posts_count']:,}"),
        ("Private", "Yes" if p['is_private'] else "No"),
        ("Verified", "Yes" if p['is_verified'] else "No"),
        ("Business", "Yes" if p['is_business'] else "No"),
    ]
    if p['external_url']:
        info.append(("Website", p['external_url']))

    for k, v in info:
        print(f"  {c(k+':', C.C):<14} {v}")

    if p['biography_hashtags']:
        print(f"  {c('Bio Tags:', C.C):<14} {' '.join(c('#'+h, C.Y) for h in p['biography_hashtags'])}")
    if p['biography_mentions']:
        print(f"  {c('Bio Mentions:', C.C):<14} {' '.join(c('@'+m, C.M) for m in p['biography_mentions'])}")

    # Analytics
    if a:
        print(c("\n  📊 Post Analytics (last {} posts)".format(a['total_analyzed']), C.BOLD))
        print(f"    Images: {a['images']}  Videos: {a['videos']} ({a['video_ratio']}%)")
        print(f"    Total Likes: {a['total_likes']:,}  Total Comments: {a['total_comments']:,}")
        print(f"    Avg Likes: {a['avg_likes_per_post']:,}  Avg Comments: {a['avg_comments_per_post']:,}")
        if a['top_hashtags']:
            print(f"    Top Hashtags: {', '.join(c('#'+t, C.Y)+f'({c})' for t,c in a['top_hashtags'][:5])}")
        if a['top_posting_hours']:
            print(f"    Peak Hours (UTC): {', '.join(f'{h}:00({c})' for h,c in a['top_posting_hours'])}")

    # Highlights
    if data.get('highlights'):
        print(c("\n  📌 Story Highlights", C.BOLD))
        for h in data['highlights']:
            print(f"    • {h['title']} ({h['item_count']} items)")

    # Stories
    if data.get('stories'):
        print(c("\n  📸 Active Stories (24h)", C.BOLD))
        for s in data['stories'][:5]:
            print(f"    • {s['date_utc']} - {s['type']}")

    # Followers analysis
    if fa:
        print(c("\n  👥 Followers Sample", C.BOLD))
        print(f"    Sample: {fa['sample_size']} | Private: {fa['private_pct']}% | Verified: {fa['verified_pct']}%")
        print(f"    Avg Followers: {fa['avg_followers']:,} | Avg Posts: {fa['avg_posts']:.1f}")
        if fa['top_influential']:
            top = ', '.join(f"@{f['username']} ({f['followers']:,})" for f in fa['top_influential'][:3])
            print(f"    Top: {top}")

    # Verbose: recent posts
    if verbose and data.get('posts'):
        print(c("\n  📝 Recent Posts", C.BOLD))
        for post in data['posts'][:5]:
            media = "🎥" if post['is_video'] else "🖼️"
            date = datetime.fromisoformat(post['date_utc']).strftime('%Y-%m-%d %H:%M')
            cap = (post['caption'][:60] + '...') if post['caption'] and len(post['caption']) > 60 else post['caption'] or ''
            print(f"    {media} {date} | ❤️{post['likes']:,} 💬{post['comments']:,} | {cap}")

def main():
    parser = argparse.ArgumentParser(
        description='osgr - Instagram OSINT Reconnaissance Tool',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=textwrap.dedent('''
        Examples:
          osgr nasa                    # Basic profile info
          osgr nasa --stories          # Include active stories
          osgr nasa --analytics        # Post analytics (30 posts)
          osgr nasa --full             # Everything (posts, highlights, stories, followers, following, comments)
          osgr nasa --followers 100    # Get 100 followers sample
          osgr nasa --following 50     # Get 50 following sample
          osgr nasa --comments 10      # Get comments from last 10 posts
          osgr nasa --save             # Save JSON + CSV + Markdown report
          osgr nasa --csv              # Save CSV exports
          osgr nasa --json             # Output raw JSON to stdout
          osgr nasa --verbose -v       # Verbose output with recent posts
        ''')
    )
    parser.add_argument('username', help='Target username (with or without @)')
    parser.add_argument('--stories', action='store_true', help='Fetch active 24h stories')
    parser.add_argument('--analytics', action='store_true', help='Analyze posts (default: 30)')
    parser.add_argument('--posts', type=int, default=30, help='Number of posts to analyze (default: 30)')
    parser.add_argument('--followers', type=int, metavar='N', help='Fetch N followers sample')
    parser.add_argument('--following', type=int, metavar='N', help='Fetch N following sample')
    parser.add_argument('--comments', type=int, metavar='N', help='Fetch comments from last N posts')
    parser.add_argument('--full', action='store_true', help='Full analysis (posts+stories+highlights+followers+following+comments)')
    parser.add_argument('--save', action='store_true', help='Save JSON + CSV + Markdown report')
    parser.add_argument('--csv', action='store_true', help='Save CSV exports')
    parser.add_argument('--json', action='store_true', help='Output raw JSON to stdout')
    parser.add_argument('--verbose', '-v', action='store_true', help='Verbose output')
    parser.add_argument('--debug', action='store_true', help='Debug mode')

    args = parser.parse_args()

    if len(sys.argv) == 1:
        parser.print_help()
        sys.exit(1)

    target = args.username.lstrip('@')
    post_limit = 100 if args.full else args.posts

    print_banner()
    print(f"  Target: {c('@'+target, C.G)} | Session: {c('loaded', C.G)}")

    osgr = OSGR(debug=args.debug)

    try:
        print(f"  Fetching profile...", end=' ', flush=True)
        profile = osgr.get_profile(target)
        print(c("OK", C.G))

        data = {'profile': osgr.extract_profile(profile)}

        print(f"  Fetching highlights...", end=' ', flush=True)
        data['highlights'] = osgr.extract_highlights(profile)
        print(c("OK", C.G))

        if args.analytics or args.full or args.posts != 30:
            print(f"  Analyzing {post_limit} posts...", end=' ', flush=True)
            posts = osgr.extract_posts(profile, post_limit)
            data['posts'] = posts
            data['analysis'] = osgr.analyze_posts(posts)
            print(c("OK", C.G))

        if args.full or args.stories:
            print(f"  Fetching stories...", end=' ', flush=True)
            data['stories'] = osgr.extract_stories(profile)
            print(c("OK", C.G))

        if args.full or args.followers:
            flimit = 200 if args.full else args.followers
            print(f"  Fetching {flimit} followers...", end=' ', flush=True)
            followers = osgr.extract_followers_sample(profile, flimit)
            data['followers_sample'] = followers
            data['followers_analysis'] = osgr.analyze_followers(followers)
            print(c("OK", C.G))

        if args.full or args.following:
            flimit = 200 if args.full else args.following
            print(f"  Fetching {flimit} following...", end=' ', flush=True)
            data['following_sample'] = osgr.extract_following_sample(profile, flimit)
            print(c("OK", C.G))

        if args.full or args.comments:
            climit = 10 if args.full else args.comments
            print(f"  Fetching comments from {climit} posts...", end=' ', flush=True)
            data['comments'] = osgr.extract_comments(profile, climit)
            print(c("OK", C.G))

        # Output
        if args.json:
            print(json.dumps(data, indent=2, default=str))
        else:
            format_output(data, args.verbose)

        # Save
        if args.save or args.csv or args.full:
            print(c("\n  Saving files...", C.Y))
            if args.save or args.full:
                json_path = osgr.save_json(data, target)
                print(f"    JSON:  {json_path}")
                csv_paths = osgr.save_csv(data, target)
                for cp in csv_paths:
                    print(f"    CSV:   {cp}")
                md_path = osgr.save_report(data, target)
                print(f"    MD:    {md_path}")
            elif args.csv:
                csv_paths = osgr.save_csv(data, target)
                for cp in csv_paths:
                    print(f"    CSV:   {cp}")

    except instaloader.exceptions.ProfileNotExistsException:
        print(c(f"\n  Profile '@{target}' does not exist", C.R))
        sys.exit(1)
    except instaloader.exceptions.LoginRequiredException:
        print(c("\n  Login required. Open Chrome → instagram.com → login as carte_r8934", C.R))
        sys.exit(1)
    except Exception as e:
        print(c(f"\n  Error: {e}", C.R))
        if args.debug or args.verbose:
            import traceback
            traceback.print_exc()
        sys.exit(1)


